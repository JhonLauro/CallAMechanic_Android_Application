<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_stat_card"
    android:orientation="vertical"
    android:padding="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ivUserIcon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="User profile"
            android:src="@drawable/ic_person"
            android:tint="@color/cam_text" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

        <TextView
            android:id="@+id/tvUserName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="User Name"
            android:textColor="@color/cam_text"
            android:textSize="17sp"
            android:textStyle="bold" />

            <TextView
                android:id="@+id/tvUserId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="#1"
                android:textColor="@color/cam_subtext"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvUserRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_blue"
            android:paddingStart="10dp"
            android:paddingTop="5dp"
            android:paddingEnd="10dp"
            android:paddingBottom="5dp"
            android:text="CLIENT"
            android:textColor="@color/cam_primary"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvUserEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_detail_soft_panel"
        android:padding="12dp"
        android:text="email@example.com"
        android:textColor="@color/cam_subtext" />

    <TextView
        android:id="@+id/tvUserExtra"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_detail_soft_panel"
        android:padding="12dp"
        android:text="Phone / Mechanic ID"
        android:textColor="@color/cam_subtext" />

    <TextView
        android:id="@+id/btnDeleteUser"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_danger_outline"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="Delete User"
        android:textColor="@color/cam_danger"
        android:textStyle="bold" />
</LinearLayout>
