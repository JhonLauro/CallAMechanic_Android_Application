<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_stat_card"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvJobIdAdmin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="#2"
        android:textColor="@color/cam_text"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvClientName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Client Name"
        android:textColor="@color/cam_text"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/tvVehicleInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Vehicle"
        android:textColor="@color/cam_subtext" />

    <TextView
        android:id="@+id/tvServiceTypeAdmin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Service Type"
        android:textColor="@color/cam_subtext" />

    <TextView
        android:id="@+id/tvMechanicAdmin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Mechanic"
        android:textColor="@color/cam_subtext" />

    <TextView
        android:id="@+id/tvStatusAdmin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_chip_blue"
        android:paddingLeft="12dp"
        android:paddingTop="6dp"
        android:paddingRight="12dp"
        android:paddingBottom="6dp"
        android:text="In Progress"
        android:textColor="@color/cam_primary"
        android:textStyle="bold" />
</LinearLayout>