<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_toolbar_icon"
                android:padding="8dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="App Logo"
                    android:src="@drawable/ic_cam_logo" />
            </FrameLayout>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="Call-A-Mechanic"
                android:textColor="@color/cam_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/btnCreateMechanicCancel"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:background="@drawable/bg_secondary_button"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:minWidth="92dp"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="14dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="7dp"
                    android:src="@drawable/ic_arrow_back" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Back"
                    android:textColor="@color/cam_primary"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Create New Mechanic"
            android:textColor="@color/cam_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Add a mechanic account that can claim and update repair jobs"
            android:textColor="@color/cam_subtext"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_stat_card"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Full Name"
                android:textColor="@color/cam_text"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etMechanicFullName"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:hint="Mechanic full name"
                android:padding="14dp"
                android:textColor="@color/cam_text"
                android:textColorHint="@color/cam_subtext" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Email Address"
                android:textColor="@color/cam_text"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etMechanicEmail"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:hint="mechanic@email.com"
                android:inputType="textEmailAddress"
                android:padding="14dp"
                android:textColor="@color/cam_text"
                android:textColorHint="@color/cam_subtext" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Phone Number"
                android:textColor="@color/cam_text"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etMechanicPhone"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:hint="09123456789"
                android:inputType="phone"
                android:padding="14dp"
                android:textColor="@color/cam_text"
                android:textColorHint="@color/cam_subtext" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Password"
                android:textColor="@color/cam_text"
                android:textStyle="bold" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp">

                <EditText
                    android:id="@+id/etMechanicPassword"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_input"
                    android:hint="Minimum 8 characters"
                    android:inputType="textPassword"
                    android:paddingStart="14dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="52dp"
                    android:paddingBottom="14dp"
                    android:textColor="@color/cam_text"
                    android:textColorHint="@color/cam_subtext" />

                <ImageButton
                    android:id="@+id/btnToggleMechanicPassword"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="4dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="Show mechanic password"
                    android:padding="10dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_eye_off" />
            </FrameLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Mechanic ID"
                android:textColor="@color/cam_text"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etMechanicId"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:hint="e.g. 01-001"
                android:padding="14dp"
                android:textColor="@color/cam_text"
                android:textColorHint="@color/cam_subtext" />

            <TextView
                android:id="@+id/tvCreateMechanicError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/cam_danger"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/progressBarCreateMechanic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btnCreateMechanicSubmit"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_primary_button"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="Create Mechanic"
                android:textColor="@android:color/white"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
