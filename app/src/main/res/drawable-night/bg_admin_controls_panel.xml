<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:angle="135"
                android:startColor="#102A4A"
                android:centerColor="#10223A"
                android:endColor="#0C1A2E" />
            <corners android:radius="20dp" />
            <stroke
                android:width="1dp"
                android:color="#355F94" />
        </shape>
    </item>
    <item android:left="0dp" android:top="0dp" android:right="0dp" android:bottom="0dp">
        <shape>
            <corners android:radius="20dp" />
            <stroke
                android:width="2dp"
                android:color="#60A5FA" />
        </shape>
    </item>
</layer-list>
